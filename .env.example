# last-quarter — optional paid API keys (self-serve). Copy to .env or put in
# ~/.config/last-quarter/.env. The free tier works with NONE of these set.
# Real environment variables take precedence over this file.

# Entity-resolved news (fixes common-word name collisions). https://exa.ai
EXA_API_KEY=

# Renders JS-shell blogs the free tier can't read. https://firecrawl.dev
FIRECRAWL_API_KEY=

# Actual recent new hires (named + LinkedIn + dept rollup). https://peopledatalabs.com
PDL_API_KEY=

# (reserved) social/reviews via Apify actors — not yet wired.
APIFY_API_TOKEN=

# Optional: raise GitHub's unauthenticated rate limit.
GITHUB_TOKEN=

# Optional: contact EMAIL for the SEC EDGAR User-Agent. SEC's fair-access policy requires
# an email-shaped contact or it returns 403 (noreply-style addresses are rejected).
# Defaults to the project contact; set your own if you run at volume.
# LAST_QUARTER_CONTACT=you@example.com
